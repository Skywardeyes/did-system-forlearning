server {
    listen 443 ssl http2;
    server_name did-vc.example.com;

    ssl_certificate     /etc/nginx/tls/fullchain.pem;
    ssl_certificate_key /etc/nginx/tls/privkey.pem;

    root /var/www/did-vc/frontend;
    index index.html;

    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer always;
    add_header X-Frame-Options DENY always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'" always;

    location /api/ {
        proxy_pass http://127.0.0.1:4173;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Request-ID $request_id;
        proxy_buffering off;
    }

    location = /health {
        proxy_pass http://127.0.0.1:4173/health;
        proxy_set_header X-Forwarded-Proto https;
    }

    # The wallet is a separate static application. It never proxies private keys
    # or wallet state to the Issuer API.
    location = /wallet {
        return 301 /wallet/;
    }

    location /wallet/ {
        alias /var/www/did-vc/wallet/;
        try_files $uri $uri/ /wallet/index.html;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 80;
    server_name did-vc.example.com;
    return 301 https://$host$request_uri;
}
