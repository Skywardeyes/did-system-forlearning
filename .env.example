DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=did_vc_learning
DB_USER=did_vc_app
DB_PASSWORD=你设置的数据库密码
DB_SSL=false
KMS_MASTER_KEY=你刚刚生成的Base64主密钥
KMS_MASTER_KEY_ID=local-master-v1

# 迁移期默认同时保留 V1/V2；完成对账和前端验收后可改为 v2。
APP_DATA_MODE=dual

# 迁移期可为 true 以保留旧 public 界面；Vue 生产部署必须为 false，由 Nginx 提供静态资源。
SERVE_FRONTEND=true

# 本地演示请先执行 npm run setup:auth。生产环境应接入正式身份提供方，不开启此开关。
AUTH_LOCAL_DEV_LOGIN=false

# 生产环境必须设为 true，并由 TLS 终止层传入 X-Forwarded-Proto: https。
REQUIRE_HTTPS=false

# 只有本地演示账号需要此权限；生产管理员默认不得读取 VC 明文。
BOOTSTRAP_GRANT_CREDENTIAL_READER=false
BOOTSTRAP_GRANT_DEMO_ROLES=false

# 本地 EVM DID Registry 演示：启动 `npm run chain:node` 并部署合约后设为 true。
# 不得将 Holder 私钥、VC 明文或个人信息写入链上；只写入 Issuer DID 和 DID Document 哈希。
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=31337
# 可选：部署脚本会在 data/chain-deployment.json 保存本地合约地址；生产环境应通过受控配置注入。
BLOCKCHAIN_CONTRACT_ADDRESS=
