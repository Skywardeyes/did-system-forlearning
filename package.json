{
  "name": "did-vc-learning-lab",
  "version": "1.0.0",
  "private": true,
  "description": "DID/VC training camp graduation project for local demonstrations",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test",
    "test:unit": "node --test test/unit",
    "test:integration": "node --test test/integration",
    "test:api": "node --test test/api",
    "test:functional": "node --test test/functional",
    "test:security": "node --test test/security",
    "test:node": "node test/run-node-tests.js",
    "test:ui": "playwright test",
    "test:all": "npm run test:node && npm run test:ui"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
